# Copy to .env and fill in. Never commit .env.

# --- LLM (report commentary). Optional: leave blank to use template fallback. ---
# The client auto-detects which provider by which *_API_KEY below is set.
# Force one with LLM_PROVIDER (deepseek | glm | openai); override model with LLM_MODEL.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# DeepSeek (https://platform.deepseek.com/) — cheap, strong Chinese
DEEPSEEK_API_KEY=

# 智谱 GLM (https://open.bigmodel.cn/)
GLM_API_KEY=
GLM_MODEL=glm-4-flash

# OpenAI (foreign; needs proxy)
OPENAI_API_KEY=

# --- Notifier webhooks/tokens (fill the one(s) you use) ---

# 企业微信群机器人: 群里加机器人 -> webhook key (part after the last '/')
WECOM_BOT_KEY=

# 飞书自定义机器人: 群里加机器人 -> webhook URL
FEISHU_BOT_URL=

# PushPlus token: https://www.pushplus.plus/
PUSHPLUS_TOKEN=

# --- Paths ---
SA_DB_PATH=data/stockagent.sqlite
